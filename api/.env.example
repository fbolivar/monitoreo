# Copia a `.env` y ajusta.  cp .env.example .env  &&  php artisan key:generate
APP_NAME="Monitoreo TI API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Bogota
APP_URL=http://localhost:8000
APP_LOCALE=es

# ── Cifrado de SECRETOS de recursos/canales (pgcrypto) ────────────
# Debe COINCIDIR con el APP_CRYPTO_KEY usado en /infra (seed/datos cifrados).
APP_CRYPTO_KEY=dev_crypto_key_change_me

# ── Base de datos ─────────────────────────────────────────────────
# DEV: Postgres local (docker compose de /infra).
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=monitoreo
DB_USERNAME=monitoreo
DB_PASSWORD=monitoreo_dev
DB_SSLMODE=prefer
# PROD (Supabase): solo cambiar lo siguiente (Settings -> Database -> Connection string)
# DB_HOST=db.<ref>.supabase.co
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=<password>
# DB_SSLMODE=require

# ── Supabase Auth (validación de JWT) ─────────────────────────────
# Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=cambia_esto_por_el_jwt_secret_de_supabase
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_URL=https://<ref>.supabase.co

# ── CORS (dominio del frontend Angular en prod) ───────────────────
CORS_ALLOWED_ORIGINS=*

# ── Infra stateless ───────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Tests ─────────────────────────────────────────────────────────
# Base de datos de pruebas (recomendado separada del dev).
DB_DATABASE_TEST=monitoreo_test
