# Auto-export OFF-SITE de los respaldos de SIMON.
# Copiar a /etc/simon/offsite.env, ajustar y `chmod 600` (contiene la passphrase).
# Lo usa /usr/local/bin/simon-offsite-backup.sh (cron diario 03:00).

# Método de envío: rsync | scp | local | none
#   rsync/scp -> destino remoto por SSH (recomienda clave sin passphrase para cron)
#   local     -> copia a una ruta local (un montaje NFS/SMB ya montado)
#   none      -> deshabilitado (no-op)
OFFSITE_METODO=none

# Destino:
#   rsync/scp -> usuario@host:/ruta/backups/
#   local     -> /mnt/nas/backups   (ruta del montaje)
OFFSITE_DEST=

# Clave SSH (sin passphrase) para rsync/scp en cron. Generar con:
#   ssh-keygen -t ed25519 -N '' -f /etc/simon/offsite_key
#   ssh-copy-id -i /etc/simon/offsite_key.pub usuario@host
OFFSITE_SSH_KEY=/etc/simon/offsite_key

# Passphrase para CIFRAR el .pnnc antes de enviarlo (MUY recomendado: el archivo
# sale del servidor). Vacío = sin cifrar. Guárdala también fuera del servidor: sin
# ella el respaldo off-site no se puede restaurar.
OFFSITE_PASSPHRASE=

# Solo para METODO=local: cuántos .pnnc conservar en el destino (0 = no rotar).
OFFSITE_RETENER=14

# Si el destino es un montaje (SMB/NFS), pon aquí su ruta: el script ABORTA si no
# está montado (evita escribir en el disco local de SIMON sin avisar). Vacío = sin guarda.
OFFSITE_REQUIRE_MOUNT=
