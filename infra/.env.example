# Copia este archivo a `.env` dentro de /infra y ajusta los valores.
#   cp .env.example .env

# ── Postgres local de desarrollo ──────────────────────────────────
POSTGRES_USER=monitoreo
POSTGRES_PASSWORD=monitoreo_dev
POSTGRES_DB=monitoreo
POSTGRES_PORT=5432

# ── Cifrado de secretos de recursos (pgcrypto) ────────────────────
# Clave maestra simétrica. En desarrollo se inyecta aquí para que el seed
# pueda cifrar los secretos de ejemplo. En producción la posee la API
# (Laravel .env -> APP_CRYPTO_KEY) y NUNCA se almacena en la base de datos.
# Genera una fuerte con:  openssl rand -base64 48
APP_CRYPTO_KEY=dev_crypto_key_change_me

# ── Zona horaria ──────────────────────────────────────────────────
TZ=America/Bogota

# ── Adminer (explorador web opcional) ─────────────────────────────
ADMINER_PORT=8080
