# Copia a `.env`.  cp .env.example .env
# ── Base de datos (mismo Postgres que la API / Supabase después) ───
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=monitoreo
DB_USERNAME=monitoreo
DB_PASSWORD=monitoreo_dev
DB_SSLMODE=prefer
DB_POOL_MAX=8

# ── Cifrado de secretos ───────────────────────────────────────────
# MISMA clave con la que la API/infra cifraron los secretos (pgcrypto).
APP_CRYPTO_KEY=dev_crypto_key_change_me

# ── Probes ────────────────────────────────────────────────────────
# Timeout por defecto de los chequeos (ms).
PROBE_TIMEOUT_MS=3000
# ICMP: en Windows normalmente requiere privilegios (True). En Linux/macOS
# con sockets datagram puede ir en False.
ICMP_PRIVILEGED=true
# Nº de paquetes ICMP por chequeo (para medir RTT y pérdida).
ICMP_COUNT=4

# ── Scheduler ─────────────────────────────────────────────────────
# Pool de hebras. Los chequeos son I/O-bound: un pool amplio evita que las
# sondas SNMP lentas saturen el pool y descarten los jobs web (120s) por misfire.
SCHEDULER_MAX_WORKERS=50
# Tolerancia (s) si un chequeo se retrasa antes de descartarlo.
MISFIRE_GRACE=90
# Cada cuántos segundos se resincronizan los jobs con la BD (altas/bajas).
SYNC_INTERVAL_SEG=60

# ── Estados SOFT/HARD (anti-falsos-positivos) ─────────────────────
# Un estado "malo" (down/degraded) se confirma como HARD tras N chequeos
# consecutivos; solo entonces se abre incidencia/notifica. Mata los falsos
# positivos por un timeout/paquete perdido puntual (clave con Starlink).
MAX_CHECK_ATTEMPTS=3
# Confirmaciones para la recuperación a 'up' (1 = cierre inmediato).
RECOVERY_ATTEMPTS=1

# ── Freshness / stale-data ────────────────────────────────────────
# Si un recurso lleva más de FRESHNESS_FACTOR×intervalo (con piso FRESHNESS_MIN_SEG)
# sin chequeo, se marca 'unknown' (cubre un job muerto o un recurso mudo).
FRESHNESS_ENABLED=true
FRESHNESS_FACTOR=3
FRESHNESS_MIN_SEG=120
FRESHNESS_CHECK_SEG=60

# ── Tareas de mantenimiento de datos (rollup/purga) ───────────────
# Si True, el worker también ejecuta los rollups y la purga (fn_* de /db).
TAREAS_MANTENIMIENTO=true

# ── Forecasting de capacidad ──────────────────────────────────────
# Regresión sobre el rollup diario de métricas % (disco/mem) -> días hasta el
# techo (100%). Avisa (sin incidencia) al cruzar por debajo de FORECAST_ALERT_DIAS.
FORECAST_ENABLED=true
FORECAST_VENTANA_DIAS=30
FORECAST_MIN_DIAS=5
FORECAST_MIN_R2=0.5
FORECAST_ALERT_DIAS=14

# ── Notificaciones (FASE 5) ───────────────────────────────────────
NOTIF_ENABLED=true
# Anti-flapping: no reenviar "apertura" del mismo recurso dentro de N segundos.
NOTIF_DEDUP_COOLDOWN_SEG=600
# Reintentos de envíos fallidos.
NOTIF_MAX_INTENTOS=3
NOTIF_RETRY_INTERVAL_SEG=120

# ── Endpoint /health opcional ─────────────────────────────────────
HEALTH_ENABLED=true
HEALTH_PORT=8090

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
